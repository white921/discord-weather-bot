DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Comma-separated list of allowed guild IDs. The bot only registers
# commands on these guilds and auto-leaves any others it gets invited
# to. Leave empty for global registration (any server).
DISCORD_GUILD_IDS=
# Comma-separated list of Discord user IDs allowed to run /panel
# in addition to anyone with Administrator permission. Leave empty
# to require Administrator.
DISCORD_PANEL_USER_IDS=
DATABASE_URL=mysql://user:password@localhost:3306/weather_bot
